{
  "name": "viagensback",
  "version": "1.0.0",
  "description": "Travel Organization System - Backend API",
  "keywords": [
    "moretto",
    "travel",
    "itinerary",
    "nodejs",
    "express",
    "sequelize"
  ],
  "homepage": "https://github.com/mario-laux-neto/gestao-de-viagens#readme",
  "bugs": {
    "url": "https://github.com/mario-laux-neto/gestao-de-viagens/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mario-laux-neto/gestao-de-viagens.git"
  },
  "license": "ISC",
  "author": "mario-laux-neto",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all",
    "db:reset": "sequelize-cli db:migrate:undo:all && sequelize-cli db:migrate && sequelize-cli db:seed:all"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.0.0"
  }
}